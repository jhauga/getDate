{
  "name": "@jhauga/getdate",
  "version": "1.0.0",
  "description": "Get the current date in various formats with flexible options. Cross-platform Node.js utility for date retrieval, formatting, and calculation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "test:make-user-test": "node scripts/make-user-test.js",
    "test:user": "node tests/userTest.js",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "date",
    "datetime",
    "format",
    "utility",
    "month",
    "quarter",
    "year",
    "getdate"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
